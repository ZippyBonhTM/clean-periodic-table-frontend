# These are NEXT_PUBLIC vars and must be correct at image build time
NEXT_PUBLIC_AUTH_API_URL=https://<FILL_AUTH_PUBLIC_DOMAIN>
NEXT_PUBLIC_BACKEND_API_URL=https://<FILL_BACKEND_PUBLIC_DOMAIN>

# Runtime-only server envs used by Next server routes and SSR guards
AUTH_API_URL=https://<FILL_AUTH_PRIVATE_OR_PUBLIC_DOMAIN>
BACKEND_API_URL=https://<FILL_BACKEND_PRIVATE_OR_PUBLIC_DOMAIN>
ADMIN_API_URL=

# Rollout control for admin authority migration
# Keep legacy-auth in production until backend admin authority is validated.
ADMIN_AUTHZ_SOURCE=legacy-auth
# Staging/next step:
# ADMIN_AUTHZ_SOURCE=auto
